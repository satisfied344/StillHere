yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json.bak

# ── Editor / OS junk ──────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# ── Build output ──────────────────────────
dist/
build/
.next/
out/

# ── Logs ──────────────────────────────────
*.log
logs/
